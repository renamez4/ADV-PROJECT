<%- include('../partials/header') %>
    <div class="card" style="max-width: 600px; margin: 2rem auto;">
        <div class="card-header">
            <h2>เพิ่มรายการบริการ</h2>
        </div>
        <div style="padding: 1.5rem;">
            <form action="/service-items" method="POST">
                <div class="form-group">
                    <label>ชื่อบริการ</label>
                    <input type="text" name="itemName" required placeholder="เช่น เปลี่ยนน้ำมันเครื่อง">
                </div>
                <div class="form-group">
                    <label>ราคามาตรฐาน (บาท)</label>
                    <input type="number" name="price" step="0.01" required placeholder="0.00">
                </div>
                <div style="display: flex; gap: 1rem;">
                    <button type="submit" class="btn btn-primary">บันทึกรายการ</button>
                    <a href="/service-items" class="btn" style="background: var(--secondary); color: white;">ยกเลิก</a>
                </div>
            </form>
        </div>
    </div>
    <%- include('../partials/footer') %>