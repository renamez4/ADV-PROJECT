<%- include('../partials/header') %>
    <div class="card" style="max-width: 800px; margin: 2rem auto;">
        <div class="card-header">
            <h2>บันทึกการรับบริการใหม่</h2>
        </div>
        <div style="padding: 1.5rem;">
            <form action="/service-records" method="POST">
                <div class="dashboard-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin: 0 0 1.5rem 0;">
                    <div class="form-group">
                        <label> ทะเบียนรถยนต์</label>
                        <select name="carId" required>
                            <% cars.forEach(car=> { %>
                                <option value="<%= car.id %>">
                                    <%= car.plateNumber %> (<%= car.brand %>)
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>ช่างผู้ดูแล</label>
                        <select name="mechanicId" required>
                            <% mechanics.forEach(mechanic=> { %>
                                <option value="<%= mechanic.id %>">
                                    <%= mechanic.mechanicName %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>วันที่เข้ารับบริการ</label>
                    <input type="date" name="serviceDate" required
                        value="<%= new Date().toISOString().split('T')[0] %>">
                </div>

                <div class="form-group">
                    <label>รายการบริการ (เลือกได้หลายรายการ)</label>
                    <div
                        style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; padding: 1rem; border: 1px solid var(--border); border-radius: 8px; background: #f8fafc;">
                        <% items.forEach(item=> { %>
                            <label style="font-weight: 400; display: flex; align-items: center; gap: 0.5rem;">
                                <input type="checkbox" name="serviceItems" value="<%= item.id %>" style="width: auto;">
                                <%= item.itemName %> (<%= item.price %> บาท)
                            </label>
                            <% }) %>
                    </div>
                </div>

                <div class="form-group">
                    <label>รายละเอียดเพิ่มเติม / หมายเหตุ</label>
                    <textarea name="description" rows="3"
                        placeholder="ระบุอาการเบื้องต้นหรือรายละเอียดการซ่อม"></textarea>
                </div>

                <div style="display: flex; gap: 1rem; border-top: 1px solid var(--border); padding-top: 1.5rem;">
                    <button type="submit" class="btn btn-primary"
                        style="flex: 1; justify-content: center;">บันทึกและคำนวณเงิน</button>
                    <a href="/service-records" class="btn"
                        style="background: var(--secondary); color: white;">ยกเลิก</a>
                </div>
            </form>
        </div>
    </div>
    <%- include('../partials/footer') %>