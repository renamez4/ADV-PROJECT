<%- include('../partials/header') %>
    <div class="card card-md" style="padding: 0; overflow: hidden;">
            <!-- Header Section -->
            <div style="background: #1e293b; color: white; padding: 2rem; display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h1 style="margin: 0; font-size: 1.5rem; letter-spacing: 1px;">ใบประวัติการรับบริการ</h1>
                    <p style="margin: 5px 0 0 0; opacity: 0.8; font-size: 0.9rem;">Service Record ID: #<%= record.id %></p>
                </div>
                <div style="text-align: right;">
                    <div style="font-weight: bold; font-size: 1.1rem;"><%= record.serviceDate %></div>
                    <span style="display: inline-block; background: var(--success); color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; margin-top: 5px;">
                        ชำระเงินแล้ว
                    </span>
                </div>
            </div>

            <div style="padding: 2.5rem;">
                <!-- Info Grid -->
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 2px dashed var(--border);">
                    <div>
                        <div style="color: var(--secondary); font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 0.8rem; display: flex; align-items: center; gap: 5px;">
                            <span style="font-size: 1.2rem;">🚗</span> ข้อมูลพาหนะ
                        </div>
                        <div style="background: #f8fafc; padding: 1rem; border-radius: 8px;">
                            <p style="margin: 0; font-size: 1.25rem; font-weight: 800; color: var(--primary);">
                                <%= record.Car.plateNumber %>
                            </p>
                            <p style="margin: 5px 0 0 0; font-weight: 500;">
                                <%= record.Car.brand %> <%= record.Car.model %>
                            </p>
                        </div>
                    </div>
                    <div>
                        <div style="color: var(--secondary); font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 0.8rem; display: flex; align-items: center; gap: 5px;">
                            <span style="font-size: 1.2rem;">🔧</span> ช่างผู้รับผิดชอบ
                        </div>
                        <div style="background: #f8fafc; padding: 1rem; border-radius: 8px;">
                            <p style="margin: 0; font-weight: 700; font-size: 1.1rem;">
                                <%= record.Mechanic.mechanicName %>
                            </p>
                            <p style="margin: 5px 0 0 0; font-size: 0.9rem; color: var(--secondary);">
                                ความเชี่ยวชาญ: <%= record.Mechanic.skillLevel %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Items Table -->
                <div style="margin-bottom: 3rem;">
                    <h3 style="font-size: 1rem; margin-bottom: 1.2rem; display: flex; align-items: center; gap: 10px;">
                        <span style="width: 4px; height: 20px; background: var(--primary); display: block; border-radius: 2px;"></span>
                        รายการที่ดำเนินการ
                    </h3>
                    <table class="table-compact">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>รายการบริการ</th>
                                <th style="text-align: right;">ราคา (บาท)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% record.ServiceItems.forEach((item, index) => { %>
                                <tr>
                                    <td style="color: var(--secondary); width: 40px;"><%= index + 1 %></td>
                                    <td style="font-weight: 500;"><%= item.itemName %></td>
                                    <td style="text-align: right; font-weight: 600;">
                                        <%= parseFloat(item.ServiceDetail.unitPrice).toLocaleString() %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="2" style="text-align: right; font-weight: 700; padding-top: 2rem;">ยอดรวมสุทธิทั้งสิ้น</td>
                                <td style="text-align: right; font-size: 1.75rem; font-weight: 800; color: var(--primary); padding-top: 2rem;">
                                    ฿<%= parseFloat(record.totalCost).toLocaleString() %>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Notes Section -->
                <% if (record.description) { %>
                    <div style="background: #fffbeb; padding: 1.5rem; border-radius: 8px; border-left: 4px solid var(--accent); margin-bottom: 3rem;">
                        <h4 style="margin: 0 0 0.5rem 0; color: #92400e; font-size: 0.9rem;">📝 บันทึกเพิ่มเติมจากช่าง:</h4>
                        <p style="margin: 0; color: #78350f; font-size: 0.95rem; line-height: 1.5;">
                            <%= record.description %>
                        </p>
                    </div>
                <% } %>

                <!-- Actions -->
                <div style="display: flex; gap: 1rem; border-top: 1px solid var(--border); padding-top: 2rem; justify-content: space-between;">
                    <a href="/service-records" class="btn" style="background: #e2e8f0; color: #475569;">
                        ⬅ กลับไปหน้ารายการ
                    </a>
                    <button onclick="window.print()" class="btn btn-primary" style="display: flex; align-items: center; gap: 8px; padding: 12px 25px;">
                        <span style="font-size: 1.2rem;">🖨️</span> พิมพ์ใบเสร็จชุดนี้
                    </button>
                </div>
            </div>
        </div>
<%- include('../partials/footer') %>