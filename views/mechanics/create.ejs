<%- include('../partials/header') %>
    <div class="card" style="max-width: 600px; margin: 2rem auto;">
        <div class="card-header">
            <h2>เพิ่มช่างใหม่</h2>
        </div>
        <div style="padding: 1.5rem;">
            <form action="/mechanics" method="POST">
                <div class="form-group">
                    <label>ชื่อช่าง</label>
                    <input type="text" name="mechanicName" required placeholder="เช่น ช่างเก่ง ดีเยี่ยม">
                </div>
                <div class="form-group">
                    <label>ระดับความชำนาญ</label>
                    <select name="skillLevel" required>
                        <option value="Junior">Junior</option>
                        <option value="Intermediate">Intermediate</option>
                        <option value="Senior">Senior</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>เบอร์โทรศัพท์</label>
                    <input type="text" name="phone" required placeholder="เช่น 0855555555">
                </div>
                <div style="display: flex; gap: 1rem;">
                    <button type="submit" class="btn btn-primary">บันทึกข้อมูล</button>
                    <a href="/mechanics" class="btn" style="background: var(--secondary); color: white;">ยกเลิก</a>
                </div>
            </form>
        </div>
    </div>
    <%- include('../partials/footer') %>