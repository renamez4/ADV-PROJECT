<%- include('../partials/header') %>
    <div class="card">
        <div class="card-header">
            <h2>รายชื่อช่างซ่อม</h2>
            <a href="/mechanics/new" class="btn btn-primary">➕ เพิ่มช่างใหม่</a>
        </div>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>ชื่อช่าง</th>
                        <th>ระดับความชำนาญ</th>
                        <th>เบอร์โทรศัพท์</th>
                        <th>จัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    <% mechanics.forEach(mechanic=> { %>
                        <tr>
                            <td>
                                <%= mechanic.mechanicName %>
                            </td>
                            <td><span class="btn btn-sm" style="background: #e2e8f0; color: #1e293b;">
                                    <%= mechanic.skillLevel %>
                                </span></td>
                            <td>
                                <%= mechanic.phone %>
                            </td>
                            <td>
                                <a href="/mechanics/<%= mechanic.id %>/edit" class="btn btn-sm btn-primary">แก้ไข</a>
                                <form action="/mechanics/<%= mechanic.id %>?_method=DELETE" method="POST"
                                    style="display:inline;" onsubmit="return confirm('ลบข้อมูลช่างซ่อม?')">
                                    <button type="submit" class="btn btn-sm btn-danger">ลบ</button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <%- include('../partials/footer') %>