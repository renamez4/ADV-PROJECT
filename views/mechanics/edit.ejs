<%- include('../partials/header') %>
    <div class="card" style="max-width: 600px; margin: 2rem auto;">
        <div class="card-header">
            <h2>แก้ไขข้อมูลช่าง</h2>
        </div>
        <div style="padding: 1.5rem;">
            <form action="/mechanics/<%= mechanic.id %>?_method=PUT" method="POST">
                <div class="form-group">
                    <label>ชื่อช่าง</label>
                    <input type="text" name="mechanicName" value="<%= mechanic.mechanicName %>" required
                        placeholder="เช่น ช่างเก่ง ดีเยี่ยม">
                </div>
                <div class="form-group">
                    <label>ระดับความชำนาญ</label>
                    <select name="skillLevel" required>
                        <option value="Junior" <%=mechanic.skillLevel==='Junior' ? 'selected' : '' %>>Junior</option>
                        <option value="Intermediate" <%=mechanic.skillLevel==='Intermediate' ? 'selected' : '' %>
                            >Intermediate</option>
                        <option value="Senior" <%=mechanic.skillLevel==='Senior' ? 'selected' : '' %>>Senior</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>เบอร์โทรศัพท์</label>
                    <input type="text" name="phone" value="<%= mechanic.phone %>" required
                        placeholder="เช่น 0855555555">
                </div>
                <div style="display: flex; gap: 1rem;">
                    <button type="submit" class="btn btn-primary">บันทึกการแก้ไข</button>
                    <a href="/mechanics" class="btn" style="background: var(--secondary); color: white;">ยกเลิก</a>
                </div>
            </form>
        </div>
    </div>
    <%- include('../partials/footer') %>