<%- include('../partials/header') %>
    <div class="card card-sm">
        <div class="card-header">
            <h2>เพิ่มลูกค้าใหม่</h2>
        </div>
        <div style="padding: 1.5rem;">
            <form action="/customers" method="POST">
                <div class="form-group">
                    <label>ชื่อ-นามสกุล</label>
                    <input type="text" name="fullName" required placeholder="เช่น นายสมชาย รักรถ">
                </div>
                <div class="form-group">
                    <label>เบอร์โทรศัพท์</label>
                    <input type="text" name="phone" required placeholder="เช่น 0812345678">
                </div>
                <div class="form-group">
                    <label>อีเมล</label>
                    <input type="email" name="email" placeholder="example@mail.com">
                </div>
                <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                    <button type="submit" class="btn btn-primary" style="flex: 1;">บันทึกข้อมูล</button>
                    <a href="/customers" class="btn" style="background: var(--secondary); color: white; flex: 1; text-align: center;">ยกเลิก</a>
                </div>
            </form>
        </div>
    </div>
    <%- include('../partials/footer') %>