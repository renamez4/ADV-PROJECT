<%- include('../partials/header') %>
    <div class="card" style="max-width: 600px; margin: 2rem auto;">
        <div class="card-header">
            <h2>แก้ไขข้อมูลลูกค้า</h2>
        </div>
        <div style="padding: 1.5rem;">
            <form action="/customers/<%= customer.id %>?_method=PUT" method="POST">
                <div class="form-group">
                    <label>ชื่อ-นามสกุล</label>
                    <input type="text" name="fullName" value="<%= customer.fullName %>" required>
                </div>
                <div class="form-group">
                    <label>เบอร์โทรศัพท์</label>
                    <input type="text" name="phone" value="<%= customer.phone %>" required>
                </div>
                <div class="form-group">
                    <label>อีเมล</label>
                    <input type="email" name="email" value="<%= customer.email %>">
                </div>
                <div style="display: flex; gap: 1rem;">
                    <button type="submit" class="btn btn-primary">อัปเดตข้อมูล</button>
                    <a href="/customers" class="btn" style="background: var(--secondary); color: white;">ยกเลิก</a>
                </div>
            </form>
        </div>
    </div>
    <%- include('../partials/footer') %>