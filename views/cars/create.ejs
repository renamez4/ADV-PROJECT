<%- include('../partials/header') %>
    <div class="card" style="max-width: 600px; margin: 2rem auto;">
        <div class="card-header">
            <h2>เพิ่มรถยนต์ใหม่</h2>
        </div>
        <div style="padding: 1.5rem;">
            <form action="/cars" method="POST">
                <div class="form-group">
                    <label>ทะเบียนรถ</label>
                    <input type="text" name="plateNumber" required placeholder="เช่น กข 1234">
                </div>
                <div class="form-group">
                    <label>ยี่ห้อรถ</label>
                    <input type="text" name="brand" required placeholder="เช่น Toyota">
                </div>
                <div class="form-group">
                    <label>รุ่นรถ</label>
                    <input type="text" name="model" required placeholder="เช่น Camry">
                </div>
                <div class="form-group">
                    <label>เจ้าของรถ</label>
                    <select name="customerId" required>
                        <option value="">-- เลือกเจ้าของรถ --</option>
                        <% customers.forEach(customer=> { %>
                            <option value="<%= customer.id %>">
                                <%= customer.fullName %> (<%= customer.phone %>)
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div style="display: flex; gap: 1rem;">
                    <button type="submit" class="btn btn-primary">บันทึกข้อมูล</button>
                    <a href="/cars" class="btn" style="background: var(--secondary); color: white;">ยกเลิก</a>
                </div>
            </form>
        </div>
    </div>
    <%- include('../partials/footer') %>